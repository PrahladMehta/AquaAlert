{
  "manifest_version": 3,
  "name": "Drink Water Reminder",
  "description": "Reminds you to drink water every 2 hours and tracks your daily, weekly, and monthly intake.",
  "version": "1.0.0",
  "permissions": [
    "alarms",
    "storage",
    "windows"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Drink Water Reminder",
    "default_popup": "popup.html"
  }
}
