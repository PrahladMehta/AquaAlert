{
  "manifest_version": 3,
  "name": "AquaAlert",
  "description": "A friendly hydration buddy that reminds you to drink water and tracks your daily, weekly, and monthly intake.",
  "version": "1.1.0",
  "permissions": [
    "alarms",
    "storage",
    "windows"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "AquaAlert",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
